#!/usr/bin/env bash
# .githooks/post-push
#
# Runs automatically after every `git push`.
# 1. Reads the pushed branch + SHA from stdin
# 2. Runs `claude --print` to perform a Solution Architect review
# 3. Posts all findings as a comment on the open PR, or on the commit if no PR exists
#
# Requirements:
#   - claude  (Claude Code CLI, must be in PATH)
#   - gh      (GitHub CLI, must be authenticated: `gh auth login`)
#
# One-time setup:
#   git config core.hooksPath .githooks
#   chmod +x .githooks/post-push

set -euo pipefail

# ── Parse pushed refs ─────────────────────────────────────────────────────────
# stdin format (one line per ref): <local-ref> <local-sha> <remote-ref> <remote-sha>
BRANCH=""
SHA=""
while read -r local_ref local_sha remote_ref remote_sha; do
    # Skip branch deletions (sha = 40 zeros)
    if [ "$local_sha" != "0000000000000000000000000000000000000000" ]; then
        BRANCH="${remote_ref#refs/heads/}"
        SHA="$local_sha"
    fi
done

# Nothing useful was pushed (e.g. tags only or branch deletion)
[ -z "$BRANCH" ] && exit 0

SHORT_SHA="${SHA:0:7}"
PROJECT_DIR="$(git rev-parse --show-toplevel)"
REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null \
       || git remote get-url origin | sed 's|.*github.com[:/]\(.*\)\.git|\1|')

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  SA Review  →  $BRANCH  ($SHORT_SHA)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── Run SA review via Claude (non-interactive) ────────────────────────────────
cd "$PROJECT_DIR"

SA_OUTPUT=$(claude --print --dangerously-skip-permissions \
'You are a Senior Solution Architect. Read every source file in this directory,
then produce a structured review using this exact output format — nothing else:

## Executive Summary
2–4 sentence verdict. Overall health: GOOD / NEEDS IMPROVEMENT / CRITICAL

## Findings

### [CRITICAL] Title — file.py:line
What the issue is and why it matters.
Recommendation: ...

### [HIGH] Title — file.py:line
...

### [MEDIUM] Title — file.py:line
...

### [LOW / INFO] Title
...

## Architectural Strengths
- Bullet list of things done well

## Top 5 Recommended Actions
1. ...

Severity guide:
  CRITICAL  — security vuln, data loss, or system-breaking flaw
  HIGH      — production reliability blocker or scalability gap
  MEDIUM    — maintainability issue that slows development
  LOW/INFO  — minor improvement or best-practice note

Rules:
  - Cite file path and line number for every finding
  - Do not invent issues — only report what you see in the code
  - Skip files in: output/, downloads/, logs/, .git/, __pycache__/' \
2>&1)

# ── Build comment body ────────────────────────────────────────────────────────
COMMENT="## 🏗️ Automated SA Review
> Branch \`$BRANCH\` · commit [\`$SHORT_SHA\`](https://github.com/$REPO/commit/$SHA)

$SA_OUTPUT

---
*Auto-generated by \`.githooks/post-push\` · [view commit](https://github.com/$REPO/commit/$SHA)*"

# ── Post findings: PR comment if PR exists, commit comment otherwise ──────────
PR_NUMBER=$(gh pr list \
    --head "$BRANCH" \
    --repo "$REPO" \
    --state open \
    --json number \
    --jq '.[0].number' 2>/dev/null || true)

if [ -n "$PR_NUMBER" ] && [ "$PR_NUMBER" != "null" ]; then
    echo "  Posting on PR #$PR_NUMBER..."
    gh pr comment "$PR_NUMBER" --repo "$REPO" --body "$COMMENT"
    echo "  ✓  https://github.com/$REPO/pull/$PR_NUMBER"
else
    echo "  No open PR found — posting as commit comment..."
    gh api "repos/$REPO/commits/$SHA/comments" \
        --method POST \
        -f body="$COMMENT"
    echo "  ✓  https://github.com/$REPO/commit/$SHA"
fi

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
