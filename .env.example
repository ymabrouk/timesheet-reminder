# Azure DevOps credentials
ADO_USERNAME=you@company.com
ADO_PASSWORD=yourpassword

# Comma-separated ADO query URLs to export
QUERY_LINKS=https://azuredevops2022.yourcompany.com/DefaultCollection/PROJECT/_queries/query/QUERY-ID

# Directory where downloaded CSVs will be saved
DOWNLOAD_DIR=downloads

# Directory where daily Excel reports will be saved (report_YYYY-MM-DD.xlsx)
OUTPUT_DIR=output

# Set to false to show the browser window (recommended for on-prem NTLM/SSO servers)
HEADLESS=false

# Webex Bot token for sending daily notifications
# Create a bot at https://developer.webex.com/my-apps and paste the token here
WEBEX_TOKEN=your_webex_bot_token_here
