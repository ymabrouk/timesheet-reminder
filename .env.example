# Azure DevOps credentials
ADO_USERNAME=you@company.com
ADO_PASSWORD=yourpassword

# Comma-separated list of Azure DevOps query URLs to export
QUERY_LINKS=https://dev.azure.com/ORG/PROJECT/_queries/query/QUERY-ID-1,https://dev.azure.com/ORG/PROJECT/_queries/query/QUERY-ID-2

# Directory where downloaded CSVs will be saved
DOWNLOAD_DIR=downloads

# Directory where the dated output Excel file will be saved
# Output file will be named: consolidated_output_YYYY-MM-DD.xlsx
OUTPUT_DIR=.

# Excel template file path (must exist before running)
TEMPLATE_FILE=template.xlsx

# Set to false to show the browser window (useful for MFA/SSO)
HEADLESS=true
